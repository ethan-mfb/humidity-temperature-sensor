{
  "name": "web-api",
  "version": "1.0.0",
  "description": "HTTP API for temperature sensor data",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite-node src/index.ts",
    "build": "vite build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:once": "vitest run --watch=false",
    "typecheck": "tsc --noEmit",
    "check-formatting": "prettier --check \"src/**/*.{ts,js,json,md}\"",
    "fix-formatting": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "package": "npm run build && mkdir publish && npm pack --pack-destination publish"
  },
  "author": "Ethan Lemke",
  "license": "MIT",
  "dependencies": {
    "express": "5.1.0",
    "onoff": "6.0.3",
    "openapi3-ts": "4.4.0",
    "swagger-ui-express": "5.0.1"
  },
  "devDependencies": {
    "@types/express": "5.0.1",
    "@types/node": "22.15.18",
    "@types/swagger-ui-express": "4.1.8",
    "prettier": "3.5.3",
    "rimraf": "3.0.2",
    "ts-node": "10.9.2",
    "typescript": "5.8.3",
    "vite": "6.3.5",
    "vite-node": "3.1.3",
    "vitest": "3.1.4"
  },
  "files": [
    "README.md",
    "package.json",
    "package-lock.json",
    "dist/**"
  ]
}
